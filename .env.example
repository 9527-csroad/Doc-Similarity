# App
DEBUG=false
DEPLOY_MODE=standalone
REQUIREMENTS_FILE=requirements/base.txt

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=docsim
POSTGRES_PASSWORD=docsim123
POSTGRES_DB=docsim

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=documents

# Local
SQLITE_PATH=./data/docsim.db
CONFIG_FILE_PATH=./data/config.json
LOCAL_STORAGE_PATH=./data/files
FAISS_INDEX_PATH=./data/faiss/index.bin
FAISS_META_PATH=./data/faiss/meta.json

# Embedding
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=./models/bge-m3
EMBEDDING_DIM=1024

# Optional API Keys
OPENAI_API_KEY=
ZHIPU_API_KEY=
GLM_API_KEY=
GLM_OCR_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/layout_parsing
GLM_OCR_MODEL=glm-ocr

# Search
DEFAULT_THRESHOLD=0.8
DEFAULT_TOP_K=10
FILE_HASH_DEDUP=true

# Backends
VECTOR_STORE=faiss
STORAGE_BACKEND=local
OCR_PROVIDER=rapid
TASK_MODE=sync
